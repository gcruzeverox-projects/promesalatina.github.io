{
  "name": "promesa-latina",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma B2B de distribución de productos latinoamericanos",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "web": "pnpm --filter web dev",
    "api": "pnpm --filter api start:dev",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:push": "pnpm --filter api prisma db push",
    "db:seed": "pnpm --filter api prisma db seed",
    "db:studio": "pnpm --filter api prisma studio",
    "db:generate": "pnpm --filter api prisma generate",
    "db:reset": "pnpm --filter api prisma migrate reset"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
