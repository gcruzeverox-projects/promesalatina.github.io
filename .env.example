# =============================================================
# PROMESA LATINA — Variables de Entorno
# Copiar este archivo a .env (para api) y .env.local (para web)
# NUNCA commitear archivos .env con valores reales
# =============================================================

# ── BASE DE DATOS ─────────────────────────────────────────────
# Obtener en: https://neon.tech  o  https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/promesa_latina?sslmode=require"

# ── AUTENTICACIÓN JWT ─────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIAR_POR_STRING_ALEATORIO_64_CARACTERES"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── CLOUDINARY (imágenes) ─────────────────────────────────────
# Obtener en: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── RESEND (correos automáticos) ──────────────────────────────
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# REEMPLAZAR AQUÍ INFORMACIÓN DE PROMESA LATINA
FROM_EMAIL="Promesa Latina <noreply@promesalatina.com>"
SALES_EMAIL="ventas@promesalatina.com"

# ── BACKEND (NestJS) ──────────────────────────────────────────
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# ── FRONTEND (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="es"

# ── ADMIN ─────────────────────────────────────────────────────
ADMIN_URL="http://localhost:3000/admin"

# =============================================================
# PRODUCCIÓN — reemplazar con URLs reales al hacer deploy
# DATABASE_URL    → URL de Neon/Supabase en producción
# NEXT_PUBLIC_API_URL → https://api.promesalatina.com
# NEXT_PUBLIC_APP_URL → https://promesalatina.com
# CORS_ORIGIN     → https://promesalatina.com
# =============================================================
